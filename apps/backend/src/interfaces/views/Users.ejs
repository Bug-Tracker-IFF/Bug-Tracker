<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Lista de Usuários</title>
    <style>
        body { font-family: Arial, sans-serif; background: #f7f7f7; }
        .user-card {
            background: #fff;
            margin: 16px auto;
            padding: 18px 24px;
            border-radius: 8px;
            box-shadow: 0 2px 8px #0001;
            max-width: 400px;
        }
        .user-card h2 { margin: 0 0 8px 0; font-size: 1.2em; }
        .user-card p { margin: 2px 0; color: #333; }
    </style>
</head>
<body>
    <h1 style="text-align:center">Usuários cadastrados</h1>
    <% if (users && users.length) { %>
        <% users.forEach(function(user) { %>
            <div class="user-card">
                <h2><%= user.name %></h2>
                <p><strong>Email:</strong> <%= user.email %></p>
                <p><strong>Função:</strong> <%= user.role %></p>
                <p><strong>ID:</strong> <%= user.id %></p>
            </div>
        <% }) %>
    <% } else { %>
        <p style="text-align:center">Nenhum usuário encontrado.</p>
    <% } %>
</body>
</html>
