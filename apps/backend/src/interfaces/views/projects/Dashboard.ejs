<!DOCTYPE html>
<html class="light" lang="pt-br">
<%- include('../partials/head', { title: 'Bug Tracker - Meus Projetos' }) %>
<body class="font-display">
<div class="relative flex h-auto min-h-screen w-full bg-background-light overflow-x-hidden">
    <!-- Sidebar -->
    <%- include('../partials/sidebar', { user }) %>
    
    <!-- Main Content -->
    <div class="layout-container flex h-full grow flex-col flex-1 px-4 sm:px-6 md:px-10 lg:px-20 py-8">
        <div class="layout-content-container flex flex-col w-full max-w-6xl mx-auto flex-1">
            
            <header class="flex items-center justify-between gap-4 mb-8">
                <h1 class="text-slate-900 text-4xl font-black leading-tight tracking-tight">Meus Projetos</h1>
                <% if (user.role === 'GERENTE') { %>
                    <a href="/projects/new" class="flex cursor-pointer items-center justify-center rounded-lg h-10 px-5 bg-primary text-white text-sm font-bold tracking-wide hover:bg-primary/90 transition-colors gap-2">
                        <span class="material-symbols-outlined">add_circle</span>
                        <span>Criar Projeto</span>
                    </a>
                <% } %>
            </header>

            <% if (projects && projects.length > 0) { %>
                <div class="grid grid-cols-[repeat(auto-fit,minmax(280px,1fr))] gap-6">
                    <% projects.forEach(project => { %>
                        <a href="/projects/<%= project.id %>" class="flex flex-col gap-4 p-5 bg-white rounded-xl border border-slate-200 hover:shadow-lg hover:border-primary/50 transition-all cursor-pointer group">
                            <div class="w-full bg-slate-100 aspect-video rounded-lg flex items-center justify-center p-4">
                                <span class="material-symbols-outlined text-gray-300 text-6xl group-hover:text-primary/50 transition-colors">folder</span>
                            </div>
                            <div class="flex flex-col gap-2">
                                <p class="text-slate-900 text-lg font-bold leading-normal"><%= project.name %></p>
                                <p class="text-slate-600 text-sm font-normal leading-normal truncate"><%= project.description %></p>
                                <div class="flex items-center gap-4 mt-2">
                                    <div class="flex items-center gap-1 text-xs text-slate-500 font-medium">
                                        <span class="material-symbols-outlined text-gray-400" style="font-size: 16px;">calendar_today</span>
                                        <span><%= new Date(project.createdAt).toLocaleDateString('pt-BR') %></span>
                                    </div>
                                </div>
                            </div>
                        </a>
                    <% }); %>
                </div>
            <% } else { %>
                <!-- Empty State -->
                <div class="flex flex-col px-4 py-16 mt-8 border-2 border-dashed border-slate-300 rounded-xl">
                    <div class="flex flex-col items-center gap-6">
                        <div class="text-primary/50">
                            <span class="material-symbols-outlined" style="font-size: 64px;">draft</span>
                        </div>
                        <div class="flex max-w-md flex-col items-center gap-2">
                            <p class="text-slate-900 text-xl font-bold leading-tight tracking-tight text-center">Nenhum projeto encontrado</p>
                            <p class="text-slate-600 text-sm font-normal leading-normal text-center">
                                <% if (user.role === 'GERENTE') { %>
                                    Você ainda não possui projetos. Crie um novo para começar.
                                <% } else { %>
                                    Peça a um gerente para adicionar você a um projeto.
                                <% } %>
                            </p>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</div>
</body>
</html>
