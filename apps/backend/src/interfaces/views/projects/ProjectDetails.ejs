<!DOCTYPE html>
<html class="light" lang="pt-br">
<%- include('../partials/head', { title: `Bug Tracker - ${project.name}` }) %>
<body class="bg-background-light font-display text-gray-800 antialiased">
<div class="relative flex min-h-screen w-full overflow-x-hidden">
    <!-- Sidebar -->
    <%- include('../partials/sidebar', { user }) %>
    
    <!-- Main Content -->
    <main class="flex-1 px-4 sm:px-6 lg:px-8 py-8 lg:py-12">
        <div class="mx-auto flex max-w-7xl flex-col gap-8">
            <!-- Breadcrumbs -->
            <div class="flex flex-wrap gap-2">
                <a class="text-gray-500 text-sm font-medium leading-normal hover:text-primary" href="/projects">Todos os Projetos</a>
                <span class="text-gray-500 text-sm font-medium leading-normal">/</span>
                <span class="text-gray-900 text-sm font-medium leading-normal"><%= project.name %></span>
            </div>
            
            <!-- Page Heading -->
            <div class="flex flex-col sm:flex-row flex-wrap items-start sm:items-center justify-between gap-4">
                <div>
                    <h1 class="text-gray-900 text-3xl sm:text-4xl font-bold tracking-tight"><%= project.name %></h1>
                    <p class="text-gray-600 mt-2"><%= project.description %></p>
                </div>
                
                <% if (user.role === 'QA' || user.role === 'DESENVOLVEDOR' || user.role === 'GERENTE') { %>
                <!-- Qualquer membro pode relatar chamados (bug report) -->
                <a href="/projects/<%= project.id %>/tickets/new" class="flex items-center justify-center gap-2 rounded-lg bg-primary h-10 px-4 text-white text-sm font-bold leading-normal tracking-wide shadow-sm hover:bg-primary/90 transition-colors">
                    <span class="material-symbols-outlined text-base">bug_report</span>
                    <span>Criar Chamado</span>
                </a>
                <% } %>
            </div>

            <!-- Alerts -->
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative">
                    <span class="block sm:inline"><%= error %></span>
                </div>
            <% } %>
            <% if (typeof success !== 'undefined' && success) { %>
                <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative">
                    <span class="block sm:inline"><%= success %></span>
                </div>
            <% } %>

            <!-- Add Member Form (GERENTE) -->
            <% if (user.role === 'GERENTE') { %>
                <div class="bg-white p-6 rounded-lg border border-gray-200 shadow-sm flex flex-col gap-4">
                    <h2 class="text-lg font-bold text-gray-900">Adicionar Membro ao Projeto</h2>
                    <form action="/projects/<%= project.id %>/members" method="POST" class="flex flex-col sm:flex-row gap-4 items-end">
                        <label class="flex flex-col flex-1">
                            <span class="text-sm font-medium text-gray-700 mb-1">E-mail do Usuário</span>
                            <input type="email" name="email" required placeholder="dev@bugtracker.com ou qa@bugtracker.com" class="form-input flex w-full h-10 rounded-lg border border-gray-300 bg-background-light px-4 text-sm focus:ring-2 focus:ring-primary/50" />
                        </label>
                        <button type="submit" class="flex items-center justify-center gap-2 rounded-lg bg-gray-800 text-white h-10 px-6 text-sm font-bold transition-colors hover:bg-gray-900">
                            <span class="material-symbols-outlined text-base">person_add</span>
                            Adicionar
                        </button>
                    </form>
                </div>
            <% } %>

            <!-- Table -->
            <div class="w-full">
                <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-gray-200">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider w-[40%]">Título</th>
                                    <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider w-[15%]">Status</th>
                                    <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider w-[25%]">Responsável</th>
                                    <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider w-[20%]">Data Criação</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-200 bg-white">
                                <% if (tickets && tickets.length > 0) { %>
                                    <% tickets.forEach(ticket => { %>
                                    <tr class="hover:bg-gray-50 cursor-pointer" onclick="window.location='/tickets/<%= ticket.id %>'">
                                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= ticket.title %></td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <% 
                                              let statusColor = "bg-gray-100 text-gray-800";
                                              if (ticket.status === 'ABERTO') statusColor = "bg-red-100 text-red-700";
                                              else if (ticket.status === 'EM_ANDAMENTO') statusColor = "bg-blue-100 text-blue-700";
                                              else if (ticket.status === 'RESOLVIDO') statusColor = "bg-green-100 text-green-700";
                                              else if (ticket.status === 'FECHADO') statusColor = "bg-gray-200 text-gray-600";
                                            %>
                                            <span class="inline-flex items-center rounded-full <%= statusColor %> px-2.5 py-1 text-xs font-medium">
                                                <%= ticket.status %>
                                            </span>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                                            <%= ticket.assigneeName ? ticket.assigneeName : 'Não atribuído' %>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                            <%= new Date(ticket.createdAt).toLocaleDateString('pt-BR') %>
                                        </td>
                                    </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="4" class="px-6 py-8 text-center text-sm text-gray-500">
                                            Nenhum chamado aberto para este projeto.
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </main>
</div>
</body>
</html>
