<aside class="flex h-screen w-64 flex-col bg-white border-r border-gray-200 sticky top-0 hidden md:flex shrink-0">
    <div class="flex h-full flex-col justify-between p-4">
        <div class="flex flex-col gap-4">
            <div class="flex items-center gap-3 p-2">
                <span class="material-symbols-outlined text-primary text-3xl">bug_report</span>
                <h2 class="text-xl font-bold text-gray-900">Bug Tracker</h2>
            </div>
            
            <div class="flex flex-col gap-2 mt-4">
                <a class="flex items-center gap-3 rounded-lg px-3 py-2 text-gray-600 hover:bg-gray-100 hover:text-gray-900 transition-colors" href="/projects">
                    <span class="material-symbols-outlined">dashboard</span>
                    <p class="text-sm font-medium">Projetos</p>
                </a>
            </div>
        </div>
        
        <div class="flex flex-col gap-2">
            <a class="flex items-center gap-3 rounded-lg px-3 py-2 text-gray-600 hover:bg-gray-100 hover:text-red-600 transition-colors" href="/logout">
                <span class="material-symbols-outlined">logout</span>
                <p class="text-sm font-medium">Sair</p>
            </a>
            
            <div class="border-t border-gray-200 my-2"></div>
            
            <div class="flex items-center gap-3 p-2">
                <div class="bg-primary/20 aspect-square rounded-full size-10 flex border border-primary/30 items-center justify-center text-primary font-bold text-lg">
                    <%= user ? user.name.charAt(0).toUpperCase() : '?' %>
                </div>
                <div class="flex flex-col">
                    <h1 class="text-sm font-medium text-gray-900 truncate max-w-[120px]"><%= user ? user.name : 'Unknown' %></h1>
                    <p class="text-xs text-gray-500 font-bold"><%= user ? user.role : 'GUEST' %></p>
                </div>
            </div>
        </div>
    </div>
</aside>
