<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>Bug Tracker - Login</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#197fe6",
                        "background-light": "#f6f7f8",
                        "background-dark": "#111921",
                    },
                    fontFamily: {
                        "display": ["Manrope", "sans-serif"]
                    },
                },
            },
        }
    </script>
</head>
<body class="font-display">
<div class="relative flex h-auto min-h-screen w-full flex-col bg-background-light dark:bg-background-dark overflow-x-hidden">
    <div class="flex flex-1 justify-center items-center py-5 px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col w-full max-w-md">
            <div class="flex justify-center items-center mb-6">
                <span class="material-symbols-outlined text-primary text-4xl mr-2">bug_report</span>
                <h1 class="text-3xl font-bold text-gray-800 dark:text-white">Bug Tracker</h1>
            </div>
            <div class="bg-white dark:bg-background-dark border border-gray-200 dark:border-white/10 p-8 rounded-xl shadow-sm">
                <h1 class="text-gray-900 dark:text-white tracking-tight text-2xl font-bold leading-tight text-center pb-6">Log in to your account</h1>
                
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
                        <span class="block sm:inline"><%= error %></span>
                    </div>
                <% } %>

                <form action="/login" method="POST" class="flex flex-col gap-y-4">
                    <label class="flex flex-col w-full">
                        <p class="text-gray-600 dark:text-gray-300 text-sm font-medium leading-normal pb-2">Email</p>
                        <input name="email" type="email" required class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-lg text-gray-900 border border-gray-300 bg-white h-12 px-4 text-base font-normal leading-normal focus:ring-2 focus:ring-primary/50" placeholder="Enter your email" />
                    </label>
                    <div class="w-full">
                        <label class="flex flex-col w-full">
                            <div class="flex justify-between items-center pb-2">
                                <p class="text-gray-600 dark:text-gray-300 text-sm font-medium leading-normal">Password</p>
                            </div>
                            <div class="flex w-full flex-1 items-stretch rounded-lg">
                                <input name="password" type="password" required class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-lg text-gray-900 border border-gray-300 bg-white h-12 px-4 text-base font-normal leading-normal focus:ring-2 focus:ring-primary/50" placeholder="Enter your password" />
                            </div>
                        </label>
                    </div>
                    <button type="submit" class="flex items-center justify-center text-center font-medium text-base h-12 w-full mt-6 rounded-lg bg-primary text-white hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary/50 cursor-pointer transition-colors duration-200">Login</button>
                </form>

                <!-- Dica de teste -->
                <div class="mt-8 text-xs text-gray-500 border-t pt-4">
                    <p>Contas de Teste (Senha: 123456):</p>
                    <ul class="list-disc pl-4 mt-1">
                        <li>gerente@bugtracker.com (Admin)</li>
                        <li>qa@bugtracker.com (Reportador)</li>
                        <li>dev@bugtracker.com (Membro)</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
</body>
</html>
